# ==========================================
# KAFKA CONFIGURATION
# ==========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=data-pipeline-client
KAFKA_GROUP_ID=pipeline-consumers

# Kafka Topics
LOG_TOPIC=application-logs
METRICS_TOPIC=system-metrics
EVENTS_TOPIC=business-events
ALERTS_TOPIC=system-alerts

# Kafka Producer Settings
PRODUCER_BATCH_SIZE=16384
PRODUCER_LINGER_MS=10
PRODUCER_COMPRESSION_TYPE=gzip

# Kafka Consumer Settings
CONSUMER_AUTO_OFFSET_RESET=earliest
CONSUMER_MAX_POLL_RECORDS=500

# ==========================================
# ELASTICSEARCH CONFIGURATION
# ==========================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=pipeline
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ==========================================
# LOGSTASH CONFIGURATION
# ==========================================
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5044

# ==========================================
# KIBANA CONFIGURATION
# ==========================================
KIBANA_URL=http://localhost:5601

# ==========================================
# POSTGRESQL (Supabase) CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://pipeline_user:pipeline_pass@localhost:5432/pipeline_metadata
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=pipeline_pass
POSTGRES_DB=pipeline_metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Supabase (Production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# API GATEWAY CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_PREFIX=/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
API_KEY=your-api-key-for-services

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# ==========================================
# GCP CONFIGURATION
# ==========================================
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# GCP Compute Engine
GCP_INSTANCE_NAME=kafka-cluster-vm
GCP_INSTANCE_TYPE=e2-micro
GCP_DISK_SIZE_GB=30

# ==========================================
# RENDER CONFIGURATION
# ==========================================
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=your-service-id

# ==========================================
# VERCEL CONFIGURATION
# ==========================================
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# ==========================================
# MONITORING & OBSERVABILITY
# ==========================================
# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Grafana
GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Application Insights
LOG_LEVEL=info
ENABLE_METRICS=true
ENABLE_TRACING=true

# ==========================================
# NOTIFICATION SERVICES
# ==========================================
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#monitoring-alerts

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourproject.com
ALERT_EMAIL_TO=alerts@yourcompany.com

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ==========================================
# DATA PRODUCER CONFIGURATION
# ==========================================
# Log Producer
LOG_PRODUCER_INTERVAL_MS=1000
LOG_PRODUCER_BATCH_SIZE=10
LOG_LEVELS=DEBUG,INFO,WARNING,ERROR,CRITICAL

# Metrics Producer
METRICS_PRODUCER_INTERVAL_MS=5000
METRICS_COLLECT_CPU=true
METRICS_COLLECT_MEMORY=true
METRICS_COLLECT_DISK=true
METRICS_COLLECT_NETWORK=true

# Event Producer
EVENTS_PRODUCER_INTERVAL_MS=2000
EVENT_TYPES=user_login,user_logout,purchase,api_call

# ==========================================
# PERFORMANCE TUNING
# ==========================================
# Worker Settings
WORKER_THREADS=4
WORKER_QUEUE_SIZE=1000

# Memory Limits
MAX_MEMORY_MB=512
HEAP_SIZE_MB=256

# Connection Pools
DB_POOL_MIN=2
DB_POOL_MAX=10
REDIS_POOL_MAX=10

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_LOG_PRODUCER=true
ENABLE_METRICS_PRODUCER=true
ENABLE_EVENT_PRODUCER=true
ENABLE_ELASTICSEARCH_CONSUMER=true
ENABLE_ANALYTICS_CONSUMER=false
ENABLE_ALERTING=true
ENABLE_AUTO_SCALING=false

# ==========================================
# DEVELOPMENT/TESTING
# ==========================================
# Test Mode
TEST_MODE=false
MOCK_DATA=false
DEBUG_MODE=false

# Sample Data Generation
GENERATE_SAMPLE_DATA=true
SAMPLE_DATA_RATE=10

# ==========================================
# CI/CD CONFIGURATION
# ==========================================
# GitHub Actions
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=yourusername/data-pipeline-kafka

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# ==========================================
# BACKUP & RECOVERY
# ==========================================
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_PATH=/backups

# ==========================================
# CUSTOM APPLICATION SETTINGS
# ==========================================
APP_NAME=Data Pipeline - Kafka & ELK
APP_VERSION=1.0.0
APP_DESCRIPTION=Real-time monitoring and logging system
APP_TIMEZONE=UTC

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
DOCS_URL=http://localhost:8000

# ==========================================
# OPTIONAL SERVICES
# ==========================================
# Upstash (Alternative Kafka)
UPSTASH_KAFKA_REST_URL=
UPSTASH_KAFKA_REST_USERNAME=
UPSTASH_KAFKA_REST_PASSWORD=

# Confluent Cloud (Alternative Kafka)
CONFLUENT_BOOTSTRAP_SERVERS=
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# Elastic Cloud
ELASTIC_CLOUD_ID=
ELASTIC_CLOUD_USERNAME=
ELASTIC_CLOUD_PASSWORD=
